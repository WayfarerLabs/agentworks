{
  // Respect .gitignore so locally-generated outputs (rulesync targets the
  // dev opted into, build artifacts, venvs, etc.) are skipped automatically.
  "gitignore": true,
  // Explicit ignores cover (a) tracked-but-generated files we don't want
  // markdownlint touching (CHANGELOG.md from release-please; copilot
  // rulesync output) and (b) paths that may not be gitignored on every
  // workspace.
  "ignores": [
    "cli/.venv/**",
    "cli/.venv64/**",
    "**/CHANGELOG.md",
    ".github/copilot-instructions.md",
    ".github/instructions/**",
    ".github/agents/**",
    ".github/skills/**"
  ]
}
